# ================================
# uventorybiz – Environment Variables
# ================================
# Copy this file to .env and fill in real values. Never commit .env.
#
# Single source of truth: .env only (not .env.local).
# Server, drizzle-kit, and migration scripts all read from .env.

# --- Required ---
# PostgreSQL connection string (e.g. Neon: postgresql://user:password@host/db?sslmode=require)
DATABASE_URL=
# Neon only — connection mode (all tools read DATABASE_URL from .env):
#   Omit on Railway / production → defaults to tcp (node-pg, recommended).
#   Local dev if Neon TCP times out → uncomment the line below:
# DATABASE_DRIVER=websocket

# Secret for signing session cookies (use a long random string)
SESSION_SECRET=

# --- Server ---
# Port the server listens on (default 17009)
PORT=17009
# Node environment: development | production
NODE_ENV=development

# --- Frontend / public URL ---
# Base URL of the app (used in emails, redirects). Railway sets RAILWAY_PUBLIC_DOMAIN.
# OIDC redirect URIs must match FRONTEND_URL exactly (scheme, host, port, path — no trailing slash on origin).
# Google Cloud Console (OAuth client): register ONLY the Google callback:
#   {FRONTEND_URL}/api/auth/oidc/google/callback
# Microsoft Entra (App registration → Authentication): register ONLY the Microsoft callback (NOT the Google path):
#   {FRONTEND_URL}/api/auth/oidc/microsoft/callback
FRONTEND_URL=http://localhost:17009
# RAILWAY_PUBLIC_DOMAIN=  # Set by Railway

# --- Remote access (local dev on phone / another device) ---
# Same Wi‑Fi/LAN: start `npm run dev`, then open http://<your-pc-ip>:17009
#   (Windows: ipconfig → IPv4; server logs "Network:" URLs on startup)
# Internet tunnel: in a second terminal run `npm run tunnel` (uses localtunnel)
#   Copy the https://….loca.lt URL into FRONTEND_URL, restart `npm run dev`, then open that URL.
#   Required for OIDC redirects and email deep links while tunneled.
# Alternatives: ngrok http 17009  |  cloudflared tunnel --url http://localhost:17009

# --- Optional: OIDC (Google / Microsoft "Continue with …") ---
# Leave client IDs/secrets unset to hide those buttons (server returns 503 if hit).
# Google Cloud Console: OAuth 2.0 Client (Web), authorized redirect URI as above.
GOOGLE_OIDC_CLIENT_ID=
GOOGLE_OIDC_CLIENT_SECRET=

# Azure Portal: App registration → Redirect URI must be .../microsoft/callback (same paths as Google will fail).
# Tenant: organizations | common | or directory GUID.
MICROSOFT_OIDC_CLIENT_ID=
MICROSOFT_OIDC_CLIENT_SECRET=
MICROSOFT_OIDC_TENANT=organizations
# Comma-separated email domains allowed for OIDC (e.g. company.com). Leave empty to allow any domain.
# OIDC_ALLOWED_EMAIL_DOMAINS=

# --- Email (Gmail SMTP) ---
# If missing, email is mocked (logs only). Required for real sending.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL="uventorybiz <noreply@example.com>"

# --- TinyMCE (Vite exposes only VITE_* to the client) ---
# 1. Visit https://www.tiny.cloud/ and create an API key
# 2. Set VITE_TINYMCE_API_KEY below (safe to expose; domain-restrict in Tiny Cloud)
# VITE_TINYMCE_API_KEY=

# --- Optional: File storage ---
# Directory for private uploads (default ./uploads)
# PRIVATE_OBJECT_DIR=./uploads
# Comma-separated paths for public assets (default ./public)
# PUBLIC_OBJECT_SEARCH_PATHS=./public

# --- Optional: Vercel Blob storage ---
# BLOB_READ_WRITE_TOKEN=

# --- Optional: SMS (Twilio) ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# --- Optional: Cron / timezone ---
# TZ=UTC

# --- Optional: Hourly cron kill switch (Neon Free compute saver) ---
# Set to false to pause the hourly DB crons (appointment auto no-show) so Neon
# can scale to zero between real traffic. Staff mark no-shows manually while paused.
# Daily/weekly crons (duty spawner, reminders, health report) are unaffected.
# HOURLY_CRON_JOBS_ENABLED=false
